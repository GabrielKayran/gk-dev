# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Build output
/dist
/tmp
/out-tsc
/bazel-out
/coverage
*.tsbuildinfo

# Dependencies and package manager caches
/node_modules
.npm/
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Angular and tooling caches
/.angular/
.cache/
.eslintcache
.sass-cache/
/connect.lock
/libpeerconnection.log
testem.log
/typings
__screenshots__/

# Local environment files
.env
.env.*
!.env.example
*.local

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/*

# System files
.DS_Store
Thumbs.db
